#####################################################################
# Celestial Arc — Environment Variables
# Copy to .env and fill in your values
#####################################################################

# ── Flask ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=GENERATE_A_STRONG_KEY_HERE

# ── AI Providers (pick at least one) ──────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Supabase (production) ────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:6543/postgres

# ── Upstash Redis (rate limiting) ────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=re_xxxx
FROM_EMAIL=noreply@celestialarc.com

# ── Monitoring ───────────────────────────────────────
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ── Feature Flags ────────────────────────────────────
ENABLE_PALM_VISION=false
ENABLE_PHONE_OTP=false

# ── Google OAuth (configured in Supabase dashboard) ──
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
