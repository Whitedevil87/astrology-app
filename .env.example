# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-in-production

# Optional: OpenAI API for enhanced Guru chat (if you want AI-powered responses)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Database (use SQLite by default)
# DATABASE_PATH=instance/astrology.db

# Optional: Upload configuration
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
